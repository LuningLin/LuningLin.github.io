<div class="news">
  {% if site.news != blank %}
    {% assign news_size = site.news | size %}
    <ul class="card-text font-weight-light list-group list-group-flush">
      {% assign news = site.news | reverse %}
      {% if include.limit and page.announcements.limit %}
        {% assign news_limit = page.announcements.limit %}
      {% else %}
        {% assign news_limit = news_size %}
      {% endif %}
      {% for item in news limit: news_limit %}
        <li class="list-group-item">
          <div class="row">
            <div class="col-xs-2 col-sm-2 col-md-2 text-center date-column">
              <table class="table-cv">
                <tbody>
                  <tr>
                    <td>
                      <span
                        class="badge font-weight-bold primary-color-dark text-uppercase align-middle"
                        style="min-width: 95px; display: inline-block;"
                      >
                        {{- item.date | date: '%b %Y' -}}
                      </span>
                    </td>
                  </tr>
                </tbody>
              </table>
            </div>
            <div class="col-xs-10 col-sm-10 col-md-10 mt-2 mt-md-0">
              <div class="ml-1 ml-md-4">
                {% if item.inline %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  <a class="news-title" href="{{ item.url | relative_url }}">{{ item.title }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        </li>
      {% endfor %}
    </ul>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
